{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/data/:path*", "destination": "/data/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/(.*)", "destination": "/admin-index.html" }
  ]
}
