{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/data/:path*",
      "destination": "/data/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/games/:path*",
      "destination": "/games/:path*"
    },
    {
      "source": "/login",
      "has": [{ "type": "host", "value": "admin.codeloot.codes" }],
      "destination": "/login.html"
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "admin.codeloot.codes" }],
      "destination": "/admin-index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.codeloot.codes" }],
      "destination": "/admin-index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
